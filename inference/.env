# ============================================================
# LOCAL inference/.env — Inference module config
# ============================================================
# File nay dung cho:
#   1. Server local test (chay server tren may Windows, co GPU NVIDIA)
#   2. Client HTTP (chi can INFERENCE_* de goi server)
#
# Tren GPU pod, TAO LAI FILE NAY voi LORA_PATH tro toi weights dir
# (khong tu dong sync tu local). Xem docs/SETUP_SERVER.md hoac
# comments ben duoi.
# ============================================================

# ---- Server endpoint (chi dung cho client HTTP) -------------------
INFERENCE_ENDPOINT=http://localhost:10100

# ---- Sampling defaults (chi dung cho client HTTP) ----------------
INFERENCE_STEPS=12
INFERENCE_GUIDANCE=3.0
INFERENCE_TRUE_CFG=2.0

# ============================================================
# Server-side config (chi doc khi chay uvicorn, KHONG dung cho
# client HTTP). Cac bien ben duoi co the KHONG CAN khi chi goi
# tu client; nhung server se can neu khoi dong local.
# ============================================================

# ---- Model -------------------------------------------------------
BASE_MODEL=Qwen/Qwen-Image-Edit
# LORA_PATH: bat buoc neu khoi dong server. Thay bang duong dan that.
#   - Tren GPU pod: vi du /root/isometric-map/lora_qwen
#   - Local Windows: vi du C:/models/lora_qwen (neu co)
# Neu de trong, server se sys.exit(1) luc startup.
LORA_PATH=
LORA_ADAPTER_NAME=isometric
LORA_WEIGHT=1.0
DTYPE=bfloat16

# ---- Offload mode (case-insensitive) -----------------------------
#   group       - group CPU offload (A40 only, recommended default)
#   sequential  - sequential CPU offload (stable, slower ~20%)
#   gpu         - full GPU load (no offload, A100-80GB only)
OFFLOAD_MODE=gpu

# ---- Batching ----------------------------------------------------
# Max items trong 1 request /edit/batch.
#   A100-80GB: 2 (model 20GB + 2x activations 25GB vua du)
#   A40:       1 (khong du VRAM cho batch=2)
MAX_BATCH_SIZE=2

# ---- torch.compile (cold start chiu 3-10 phut) ------------------
#   max-autotune     - A100-80GB only, +20-40% per step
#   reduce-overhead  - safe cho ca A40, +20-30% per step
#   0                - tat torch.compile, cold start <30s
ENABLE_TORCH_COMPILE_OPT=0

# ---- VAE optimizations (mac dinh bat) ---------------------------
ENABLE_VAE_TILING_OPT=1
ENABLE_SDPA_OPT=1
